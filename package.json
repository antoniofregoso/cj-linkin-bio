{
  "name": "@customerjourney/cj-linkin-bio",
  "version": "1.5.5",
  "description": "link in bio component of the CustomerJourneyJS project",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.min.js"
    }
  },
  "scripts": {
    "prod": "esbuild src/index.js --bundle --minify --format=esm --jsx=automatic --jsx-import-source=preact --external:@customerjourney/cj-core --outfile=dist/index.min.js",
    "build": "esbuild src/index.js --bundle --format=esm --jsx=automatic --jsx-import-source=preact --external:@customerjourney/cj-core --outfile=dist/index.js",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoniofregoso/cj-linkin-bio.git"
  },
  "author": "Antonio Fregoso <antoniofregoso@protonmail.com>",
  "license": "GPL-3.0-or-later",
  "peerDependencies": {
    "@customerjourney/cj-core": "^1.13.0"
  },
  "devDependencies": {
    "@customerjourney/cj-core": "^1.13.0",
    "esbuild": "^0.25.5",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-brands-svg-icons": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "preact": "^10.29.4",
    "remarkable": "^2.0.1"
  },
  "bugs": {
    "url": "https://github.com/antoniofregoso/cj-linkin-bio.git/issues"
  },
  "homepage": "https://customerjourney.ninja/documentation/linkin-bio/",
  "keywords": [
    "vanilla-javascripts",
    "link in bio",
    "funnels",
    "touchpoints"
  ]
}
